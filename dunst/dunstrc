[global]
    #: GEOMETRY
    origin = top-right
    width = (0, 500)
    height = (0, 500)
    offset = (20, 30)
    notification_limit = 10

    #: FRAME
    transparency = 0
    padding = 10
    horizontal_padding = 10
    frame_width = 2
    frame_color = "#8caaee"
    gap_size = 3
    highlight = "#8caaee"

    #: INDICATOR
    stack_duplicates = false
    sort = update
    idle_threshold = 120

    #: TEXT
    font = JetBrainsMono Nerd Font 12
    line_height = 5
    format = "<b>%s</b>\n%b\n%p"
    ellipsize = end
    enable_posix_regex = true

    #: ICONS
    icon_corner_radius = 5
    icon_corners = all
    icon_theme = Papirus
    min_icon_size = 32
    max_icon_size = 128
    enable_recursive_icon_lookup = true

    #: CORNERS
    corner_radius = 5
    corners = all

    #: MOUSE
    mouse_left_click = open_url,context
    mouse_middle_click = close_all
    mouse_right_click = context_all

    #: WAYLAND SUPPORT
    layer = overlay
    force_xwayland = true

[shortcuts]
    close = mod4+delete
    close_all = mod4+shift+delete
    history = mod4+backspace
    context = mod4+shift+backspace

[urgency_low]
    background = "#303446"
	  foreground = "#c6d0f5"
    timeout = 5
    default_icon = dialog-information

[urgency_normal]
    background = "#303446"
    foreground = "#c6d0f5"
    timeout = 5
    override_pause_level = 30
    default_icon = dialog-information

[urgency_critical]
	  background = "#303446"
	  foreground = "#c6d0f5"
	  frame_color = "#ef9f76"
    timeout = 0
    override_pause_level = 60
    default_icon = dialog-warning
